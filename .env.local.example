# =============================================================================
# Resume Talos — Environment Variables
# Copy this file to `.env.local` and fill in values. Never commit `.env.local`.
# =============================================================================

# ----- Database -----
# Neon Postgres connection string with pgvector extension.
# Create a free project at https://console.neon.tech/, then copy the pooled
# connection string from the dashboard. Looks like:
# postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ----- Model providers -----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
XAI_API_KEY=

# ----- Output -----
# Folder where final DOCX/PDF artifacts are written.
OUTPUT_ROOT=E:\resume-talos-output

# ----- Models (override defaults if desired) -----
MODEL_WRITER=claude-opus-4-7
# JD analysis is structured extraction — Sonnet is well-suited and ~5× cheaper.
MODEL_JD_ANALYZER=claude-sonnet-4-6
MODEL_REVIEWER_A=claude-sonnet-4-6
MODEL_REVIEWER_B=grok-4-latest
MODEL_RESEARCH=gemini-2.5-pro
# Verifier role drives BOTH groundedness verification AND kb-gap query
# expansion. Grok 4 produces more nuanced grounding judgment + richer
# skill variants than Haiku, at ~10× the cost (still a small fraction of
# a full application's cost). Drop to claude-haiku-4-5 to revert.
MODEL_VERIFIER=grok-4-latest
MODEL_FIT_SCORE=claude-haiku-4-5
MODEL_SCREENER=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# ----- Knowledge Base dedup -----
# Cosine similarity threshold above which two facts of the same type are
# treated as duplicates. 0.85 catches obvious paraphrased duplicates; raise to
# 0.92+ to only catch near-identical wording.
FACT_SIMILARITY_THRESHOLD=0.85
